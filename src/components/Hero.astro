---
import { SITE } from "../data/site";
---

<section class="section" aria-labelledby="hero-heading">
  <div class="container">
    <div class="flex flex-col items-center text-center max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-border bg-muted text-sm font-medium text-muted-foreground mb-8">
        Trusted by 500+ businesses worldwide
      </div>

      <!-- Headline -->
      <h1
        id="hero-heading"
        class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl md:text-6xl lg:text-7xl"
      >
        We build digital
        <span class="block">experiences that</span>
        <span class="block text-muted-foreground">drive growth</span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-lg text-muted-foreground max-w-2xl leading-relaxed sm:text-xl">
        {SITE.description}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col items-center gap-4 mt-10 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-3.5 text-sm font-medium rounded-full bg-foreground text-background hover:bg-foreground/90 transition-colors duration-200 w-full sm:w-auto"
        >
          Start a Project
        </a>
        <a
          href="/services"
          class="inline-flex items-center justify-center px-8 py-3.5 text-sm font-medium rounded-full border border-border text-foreground hover:bg-muted transition-colors duration-200 w-full sm:w-auto"
        >
          View Our Services
        </a>
      </div>

      <!-- Stats Row -->
      <div class="grid grid-cols-3 gap-8 mt-16 pt-16 border-t border-border w-full max-w-lg">
        <div>
          <p class="text-3xl font-bold text-foreground sm:text-4xl">500+</p>
          <p class="mt-1 text-sm text-muted-foreground">Clients Served</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-foreground sm:text-4xl">98%</p>
          <p class="mt-1 text-sm text-muted-foreground">Satisfaction Rate</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-foreground sm:text-4xl">12+</p>
          <p class="mt-1 text-sm text-muted-foreground">Years Experience</p>
        </div>
      </div>
    </div>
  </div>
</section>
