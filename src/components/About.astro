---
import { SITE } from "../contants/data";
---

<section class="section bg-muted" aria-labelledby="about-heading">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- Image -->
      <div class="relative">
        <div class="aspect-[4/3] rounded-2xl bg-border overflow-hidden">
          <div class="w-full h-full flex items-center justify-center text-muted-foreground">
            <svg class="w-16 h-16 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
            </svg>
          </div>
        </div>
        <!-- Decorative accent -->
        <div class="absolute -bottom-4 -right-4 w-24 h-24 rounded-2xl bg-foreground -z-10 hidden lg:block"></div>
      </div>

      <!-- Content -->
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-3">
          About Us
        </p>
        <h2 id="about-heading" class="text-3xl font-bold text-foreground sm:text-4xl">
          A partner dedicated to your success
        </h2>
        <p class="mt-6 text-muted-foreground leading-relaxed">
          Founded with a mission to empower businesses through innovation, we have spent over a decade helping companies of all sizes achieve their goals. Our team of experts combines deep industry knowledge with creative thinking to deliver solutions that make a real difference.
        </p>
        <p class="mt-4 text-muted-foreground leading-relaxed">
          We believe in building lasting relationships, not just delivering projects. When you work with us, you get a committed partner who is invested in your long-term growth and success.
        </p>
        <div class="mt-8">
          <a
            href="/about"
            class="inline-flex items-center text-sm font-medium text-foreground hover:text-foreground/70 transition-colors duration-200 group"
          >
            Learn more about us
            <svg class="w-4 h-4 ml-2 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
