<section class="section" aria-labelledby="cta-heading">
  <div class="container">
    <div class="rounded-3xl bg-foreground text-background px-8 py-16 text-center sm:px-16 sm:py-20">
      <h2
        id="cta-heading"
        class="text-3xl font-bold text-background sm:text-4xl lg:text-5xl"
      >
        Ready to transform
        <span class="block">your business?</span>
      </h2>
      <p class="mt-4 text-background/70 max-w-xl mx-auto leading-relaxed sm:text-lg">
        Let's discuss how we can help you achieve your goals. Schedule a free consultation today and take the first step toward growth.
      </p>
      <div class="flex flex-col items-center gap-4 mt-8 sm:flex-row sm:justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-3.5 text-sm font-medium rounded-full bg-background text-foreground hover:bg-background/90 transition-colors duration-200 w-full sm:w-auto"
        >
          Schedule a Consultation
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center justify-center px-8 py-3.5 text-sm font-medium rounded-full border border-background/30 text-background hover:bg-background/10 transition-colors duration-200 w-full sm:w-auto"
        >
          View Pricing
        </a>
      </div>
    </div>
  </div>
</section>
