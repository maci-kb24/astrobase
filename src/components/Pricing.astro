---
import { PRICING_PLANS } from "../contants/data";
---

<section class="section" aria-labelledby="pricing-heading">
  <div class="container">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-3">
        Pricing
      </p>
      <h2 id="pricing-heading" class="text-3xl font-bold text-foreground sm:text-4xl">
        Simple, transparent pricing
      </h2>
      <p class="mt-4 text-muted-foreground leading-relaxed">
        Choose the plan that fits your business. All plans include a free consultation to get you started.
      </p>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 gap-6 max-w-5xl mx-auto md:grid-cols-3">
      {PRICING_PLANS.map((plan) => (
        <div
          class:list={[
            "relative flex flex-col p-8 rounded-2xl border transition-all duration-300",
            plan.highlighted
              ? "bg-foreground text-background border-foreground shadow-2xl scale-[1.02] md:scale-105"
              : "bg-background text-foreground border-border hover:shadow-lg hover:border-foreground/10",
          ]}
        >
          {plan.highlighted && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="inline-flex items-center px-4 py-1 rounded-full text-xs font-semibold bg-background text-foreground">
                Most Popular
              </span>
            </div>
          )}

          <div class="mb-6">
            <h3 class="text-lg font-semibold">{plan.name}</h3>
            <p class:list={[
              "mt-1 text-sm",
              plan.highlighted ? "text-background/70" : "text-muted-foreground",
            ]}>
              {plan.description}
            </p>
          </div>

          <div class="mb-8">
            <span class="text-4xl font-bold">${plan.price}</span>
            <span class:list={[
              "text-sm",
              plan.highlighted ? "text-background/70" : "text-muted-foreground",
            ]}>/month</span>
          </div>

          <ul class="flex-1 flex flex-col gap-3 mb-8" role="list">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm">
                <svg
                  class:list={[
                    "w-5 h-5 flex-shrink-0 mt-0.5",
                    plan.highlighted ? "text-background/80" : "text-foreground",
                  ]}
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span class={plan.highlighted ? "text-background/90" : ""}>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="/contact"
            class:list={[
              "inline-flex items-center justify-center w-full px-6 py-3 text-sm font-medium rounded-full transition-colors duration-200",
              plan.highlighted
                ? "bg-background text-foreground hover:bg-background/90"
                : "bg-foreground text-background hover:bg-foreground/90",
            ]}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
