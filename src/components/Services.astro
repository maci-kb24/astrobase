---

<section class="section" aria-labelledby="services-heading">
  <div class="container">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-3">
        What We Do
      </p>
      <h2 id="services-heading" class="text-3xl font-bold text-foreground sm:text-4xl">
        Services tailored to your needs
      </h2>
      <p class="mt-4 text-muted-foreground leading-relaxed">
        From strategy to execution, we provide end-to-end solutions that help your business thrive in the digital landscape.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {SERVICES.map((service) => (
        <div class="group p-8 rounded-2xl border border-border bg-background hover:shadow-lg hover:border-foreground/10 transition-all duration-300">
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-muted text-foreground mb-6">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[service.icon] || icons.strategy} />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-3">
            {service.title}
          </h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a
        href="/services"
        class="inline-flex items-center text-sm font-medium text-foreground hover:text-foreground/70 transition-colors duration-200 group"
      >
        View all services
        <svg class="w-4 h-4 ml-2 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
