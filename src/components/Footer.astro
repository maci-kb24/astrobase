---
import { SITE_CONFIG } from "../config";
import { NAV_ITEMS, SOCIAL_LINKS } from "../config";
import { SERVICES } from "../contants/data"; 

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-foreground text-background" role="contentinfo">
  <div class="container section">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Company Info -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="text-xl font-bold tracking-tight">
          {SITE_CONFIG.name}
        </a>
        <p class="mt-4 text-sm leading-relaxed text-background/70 max-w-xs">
          {SITE_CONFIG.description}
        </p>
        <div class="flex items-center gap-4 mt-6">
          {SOCIAL_LINKS.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-9 h-9 rounded-full bg-background/10 text-background/70 hover:bg-background/20 hover:text-background transition-colors duration-200"
              aria-label={`Visit our ${link.label} page`}
            >
              {link.icon === "twitter" && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
              )}
              {link.icon === "linkedin" && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              )}
              {link.icon === "github" && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-background/50 mb-4">
          Navigation
        </h3>
        <ul class="flex flex-col gap-3" role="list">
          {NAV_ITEMS.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-background/70 hover:text-background transition-colors duration-200"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-background/50 mb-4">
          Services
        </h3>
        <ul class="flex flex-col gap-3" role="list">
          {SERVICES.slice(0, 5).map((service) => (
            <li>
              <a
                href="/services"
                class="text-sm text-background/70 hover:text-background transition-colors duration-200"
              >
                {service.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-background/50 mb-4">
          Contact
        </h3>
        <ul class="flex flex-col gap-3 text-sm text-background/70" role="list">
          <li>
            <a href={`mailto:${SITE_CONFIG.email}`} class="hover:text-background transition-colors duration-200">
              {SITE_CONFIG.email}
            </a>
          </li>
          <li>
            <a href={`tel:${SITE_CONFIG.phone.replace(/\s/g, "")}`} class="hover:text-background transition-colors duration-200">
              {SITE_CONFIG.phone}
            </a>
          </li>
          <li>{SITE_CONFIG.address}</li>
          <li>{SITE_CONFIG.hours}</li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-background/10 flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-background/50">
        &copy; {currentYear} {SITE_CONFIG.name}. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="#" class="text-sm text-background/50 hover:text-background transition-colors duration-200">
          Privacy Policy
        </a>
        <a href="#" class="text-sm text-background/50 hover:text-background transition-colors duration-200">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
