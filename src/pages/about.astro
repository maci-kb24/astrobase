---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
---

<BaseLayout title="About" description="Learn about our story, mission, and the team behind our success.">
  <!-- Page Hero -->
  <section class="section" aria-labelledby="about-page-heading">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-3">
          About Us
        </p>
        <h1 id="about-page-heading" class="text-4xl font-bold text-foreground sm:text-5xl lg:text-6xl">
          We believe in the power of great partnerships
        </h1>
        <p class="mt-6 text-lg text-muted-foreground leading-relaxed">
          Founded with a clear mission: empower businesses to thrive through innovative digital solutions. Over the past decade, we have grown from a small team with big ideas to an award-winning agency trusted by hundreds of organizations worldwide.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="section bg-muted" aria-labelledby="mission-heading">
    <div class="container">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
        <div>
          <h2 id="mission-heading" class="text-2xl font-bold text-foreground">Our Mission</h2>
          <p class="mt-4 text-muted-foreground leading-relaxed">
            To deliver exceptional digital experiences that drive measurable business growth. We combine strategic thinking with creative execution to help our clients stand out in crowded markets and build lasting connections with their audiences.
          </p>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-foreground">Our Vision</h2>
          <p class="mt-4 text-muted-foreground leading-relaxed">
            To be the most trusted partner for businesses seeking to transform their digital presence. We envision a world where every business, regardless of size, has access to world-class digital solutions that level the playing field.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section" aria-labelledby="values-heading">
    <div class="container">
      <div class="max-w-2xl mb-12">
        <h2 id="values-heading" class="text-3xl font-bold text-foreground sm:text-4xl">
          Our core values
        </h2>
        <p class="mt-4 text-muted-foreground leading-relaxed">
          These principles guide every decision we make and every project we deliver.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: "Excellence", desc: "We hold ourselves to the highest standards in everything we do, from code quality to client communication." },
          { title: "Transparency", desc: "Honest communication and clear expectations are the foundation of every successful partnership we build." },
          { title: "Innovation", desc: "We stay ahead of the curve, continuously exploring new technologies and approaches to deliver better results." },
          { title: "Collaboration", desc: "The best outcomes come from working together. We treat every client relationship as a true partnership." },
        ].map((value) => (
          <div class="p-6 rounded-2xl border border-border">
            <h3 class="text-lg font-semibold text-foreground mb-3">{value.title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{value.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section bg-muted" aria-labelledby="team-heading">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 id="team-heading" class="text-3xl font-bold text-foreground sm:text-4xl">
          Meet our leadership
        </h2>
        <p class="mt-4 text-muted-foreground leading-relaxed">
          The experienced team driving our vision forward.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 max-w-4xl mx-auto">
        {[
          { name: "Alex Morgan", role: "Chief Executive Officer" },
          { name: "Jordan Lee", role: "Chief Technology Officer" },
          { name: "Sam Rivera", role: "Head of Design" },
        ].map((member) => (
          <div class="text-center p-8 rounded-2xl bg-background border border-border">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-muted text-foreground font-bold text-xl mb-4">
              {member.name.split(" ").map((n) => n[0]).join("")}
            </div>
            <h3 class="text-lg font-semibold text-foreground">{member.name}</h3>
            <p class="mt-1 text-sm text-muted-foreground">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
