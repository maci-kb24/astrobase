---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Blog" description="Insights, guides, and behind-the-scenes stories from our team.">
  <section class="section" aria-labelledby="blog-page-heading">
    <div class="container">
      <!-- Page Header -->
      <div class="max-w-3xl mb-16">
        <p class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-3">
          Blog
        </p>
        <h1 id="blog-page-heading" class="text-4xl font-bold text-foreground sm:text-5xl lg:text-6xl">
          Insights and updates
        </h1>
        <p class="mt-6 text-lg text-muted-foreground leading-relaxed">
          Thoughts on strategy, design, development, and building businesses that last.
        </p>
      </div>

      <!-- Posts Grid -->
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <article class="group">
              <a href={`/blog/${post.id}`} class="block">
                <!-- Image -->
                <div class="aspect-[16/10] rounded-2xl bg-muted border border-border overflow-hidden mb-5">
                  {post.data.image ? (
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-muted-foreground">
                      <svg class="w-10 h-10 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" />
                      </svg>
                    </div>
                  )}
                </div>

                <!-- Meta -->
                <div class="flex items-center gap-3 mb-3">
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="text-xs text-muted-foreground"
                  >
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <>
                      <span class="text-border">|</span>
                      <span class="text-xs text-muted-foreground">{post.data.tags[0]}</span>
                    </>
                  )}
                </div>

                <!-- Title & Description -->
                <h2 class="text-xl font-semibold text-foreground group-hover:text-foreground/70 transition-colors duration-200">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-sm text-muted-foreground leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>

                <!-- Read More -->
                <span class="inline-flex items-center mt-4 text-sm font-medium text-foreground group-hover:text-foreground/70 transition-colors duration-200">
                  Read article
                  <svg class="w-4 h-4 ml-1.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </span>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <p class="text-muted-foreground text-center py-16">No blog posts yet. Check back soon.</p>
      )}
    </div>
  </section>
</BaseLayout>
