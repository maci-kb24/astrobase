---
import BaseLayout from "../layouts/BaseLayout.astro";
import PricingComponent from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
---

<BaseLayout title="Pricing" description="Simple, transparent pricing for businesses of all sizes. Choose the plan that fits your needs.">
  <!-- Page Hero -->
  <section class="section" aria-labelledby="pricing-page-heading">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-sm font-semibold uppercase tracking-wider text-muted-foreground mb-3">
          Pricing
        </p>
        <h1 id="pricing-page-heading" class="text-4xl font-bold text-foreground sm:text-5xl lg:text-6xl">
          Invest in your growth
        </h1>
        <p class="mt-6 text-lg text-muted-foreground leading-relaxed">
          Transparent pricing with no hidden fees. Every plan includes a free initial consultation.
        </p>
      </div>
    </div>
  </section>

  <PricingComponent />
  <FAQ />
  <CTA />
</BaseLayout>
